<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <include name="View_560_PosterFiles">
        <control type="group">
            <include>OpenClose_Right</include>
            <left>50</left>
            <top>0</top>
            <visible>Control.IsVisible(560)</visible>
            <include>Visible_Right</include>
            <control type="panel" id="560">
                <left>0</left>
                <top>0</top>
                <width>98%</width>
                <height>100%</height>
                <onleft>9000</onleft>
                <onright>531</onright>
                <onup condition="Integer.IsGreater(Container.NumPages,1)">560</onup>
                <onup condition="!Integer.IsGreater(Container.NumPages,1)">9000</onup>
                <ondown>500</ondown>
                <viewtype label="31990">list</viewtype>
                <preloaditems>2</preloaditems>
                <pagecontrol>531</pagecontrol>
                <scrolltime tween="cubic" easing="out">500</scrolltime>
                <visible>Container.Content(files)</visible>
                <itemlayout height="445" width="320">
                    <control type="group">
                        <top>110</top>
                        <control type="image">
                            <left>15</left>
                            <top>-10</top>
                            <width>290</width>
                            <height>415</height>
                            <texture background="true" fallback="$INFO[ListItem.Icon]">$INFO[ListItem.Art(poster)]</texture>
                            <aspectratio>scale</aspectratio>
                        </control>
                        <control type="image">
                            <visible>ListItem.IsResumable + !Integer.IsGreater(ListItem.PlayCount,0)</visible>
                            <left>20</left>
                            <top>296</top>
                            <width>200</width>
                            <height>4</height>
                            <texture colordiffuse="66000000">colors/black.png</texture>
                        </control>
                        <control type="image">
                            <visible>!String.IsEqual(ListItem.Label,..)</visible>
                            <left>15</left>
                            <top>-10</top>
                            <width>290</width>
                            <height>415</height>
                            <texture>posterfiles/gradientNoise.png</texture>
                            <aspectratio>center</aspectratio>
                        </control>
                        <control type="progress">
                            <left>35</left>
                            <top>365</top>
                            <width>250</width>
                            <height>1</height>
                            <texturebg></texturebg>
                            <midtexture colordiffuse="button_focus" border="3">progress/texturebg_alt_white.png</midtexture>
                            <info>ListItem.PercentPlayed</info>
                            <visible>!Integer.IsEqual(ListItem.PercentPlayed,0)</visible>
                        </control>
                        <control type="image">
                            <left>254</left>
                            <top>358</top>
                            <width>24</width>
                            <height>24</height>
                            <texture>$VAR[ItemStatusIconVar]</texture>
                        </control>
                        <!-- F1 -->
                        <control type="image">
                            <visible>String.StartsWith(ListItem.Label,F1)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/f1.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <!-- MotoGP -->
                        <control type="image">
                            <visible>String.StartsWith(ListItem.Label,MotoGP) + !String.Contains(ListItem.Label,Moto2) + !String.Contains(ListItem.Label,Moto3)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/motogp.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <!-- Moto2 -->
                        <control type="image">
                            <visible>String.Contains(ListItem.Label,Moto2)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/moto2.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <!-- Moto3 -->
                        <control type="image">
                            <visible>String.Contains(ListItem.Label,Moto3)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/moto3.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <!-- UFC -->
                        <control type="image">
                            <visible>String.StartsWith(ListItem.Label,UFC)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/ufc.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <control type="textbox">
                            <left>30</left>
                            <top>290</top>
                            <width>260</width>
                            <height>110</height>
                            <font>font8_poster</font>
                            <align>center</align>
                            <aligny>top</aligny>
                            <label>$INFO[ListItem.Label]</label>
                        </control>
                    </control>
                </itemlayout>
                <focusedlayout height="445" width="320">
                    <control type="group">
                        <depth>DepthContentPopout</depth>
                        <animation effect="zoom" start="100" end="108" time="180" tween="sine" easing="inout" center="120,180">Focus</animation>
                        <animation effect="zoom" start="108" end="100" time="180" tween="sine" easing="inout" center="120,180">UnFocus</animation>
                        <top>110</top>
                        <control type="image">
                            <left>11</left>
                            <top>-14</top>
                            <width>298</width>
                            <height>423</height>
                            <texture colordiffuse="button_focus">colors/grey.png</texture>
                            <include>Animation_FocusTextureFade</include>
                        </control>
                        <control type="image">
                            <left>15</left>
                            <top>-10</top>
                            <width>290</width>
                            <height>415</height>
                            <texture background="true">$VAR[IconWallThumbVar]</texture>
                            <aspectratio>scale</aspectratio>
                        </control>
                        <control type="image">
                            <visible>ListItem.IsResumable + !Integer.IsGreater(ListItem.PlayCount,0)</visible>
                            <left>30</left>
                            <top>15</top>
                            <width>24</width>
                            <height>24</height>
                            <texture>posterfiles/resume.png</texture>
                        </control>
                        <control type="image">
                            <visible>!String.IsEqual(ListItem.Label,..)</visible>
                            <left>15</left>
                            <top>-10</top>
                            <width>290</width>
                            <height>415</height>
                            <texture>posterfiles/gradientNoise.png</texture>
                            <aspectratio>center</aspectratio>
                        </control>
                        <control type="progress">
                            <left>35</left>
                            <top>365</top>
                            <width>250</width>
                            <height>1</height>
                            <texturebg></texturebg>
                            <midtexture colordiffuse="button_focus" border="3">
        progress/texturebg_alt_white.png
    </midtexture>
                            <info>ListItem.PercentPlayed</info>
                            <visible>!Integer.IsEqual(ListItem.PercentPlayed,0)</visible>
                        </control>
                        <control type="image">
                            <left>254</left>
                            <top>358</top>
                            <width>24</width>
                            <height>24</height>
                            <texture>$VAR[ItemStatusIconVar]</texture>
                        </control>
                        <!-- F1 -->
                        <control type="image">
                            <visible>String.StartsWith(ListItem.Label,F1)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/f1.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <!-- MotoGP -->
                        <control type="image">
                            <visible>String.StartsWith(ListItem.Label,MotoGP) + !String.Contains(ListItem.Label,Moto2) + !String.Contains(ListItem.Label,Moto3)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/motogp.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <!-- Moto2 -->
                        <control type="image">
                            <visible>String.Contains(ListItem.Label,Moto2)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/moto2.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <!-- Moto3 -->
                        <control type="image">
                            <visible>String.Contains(ListItem.Label,Moto3)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/moto3.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <!-- UFC -->
                        <control type="image">
                            <visible>String.StartsWith(ListItem.Label,UFC)</visible>
                            <left>80</left>
                            <top>110</top>
                            <width>160</width>
                            <height>160</height>
                            <texture>posterfiles/icons/ufc.png</texture>
                            <aspectratio>keep</aspectratio>
                        </control>
                        <control type="textbox">
                            <left>30</left>
                            <top>290</top>
                            <width>260</width>
                            <height>110</height>
                            <font>font8_poster</font>
                            <align>center</align>
                            <aligny>top</aligny>
                            <label>$INFO[ListItem.Label]</label>
                        </control>
                    </control>
                </focusedlayout>
            </control>
        </control>
    </include>
</includes>
